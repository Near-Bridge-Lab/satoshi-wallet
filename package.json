{
  "name": "satoshi-wallet",
  "version": "0.0.1",
  "description": "Satoshi Wallet",
  "scripts": {
    "dev": "pnpm --filter=@satoshi-wallet/app dev",
    "dev:wallet": "pnpm --filter=btc-wallet dev",
    "build": "pnpm -r build",
    "build:cloudflare": "pnpm -r build:cloudflare",
    "start": "pnpm -r start",
    "clean": "pnpm -r run clean",
    "lint": "pnpm -r lint",
    "prepare": "husky"
  },
  "keywords": [
    "satoshi-wallet",
    "satoshi",
    "wallet",
    "btc",
    "near"
  ],
  "homepage": "https://github.com/Near-Bridge-Lab/satoshi-wallet",
  "repository": {
    "type": "git",
    "url": "https://github.com/Near-Bridge-Lab/satoshi-wallet.git"
  },
  "author": "Satoshi Team",
  "license": "MIT",
  "devDependencies": {
    "@types/big.js": "^6.2.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.7.5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5"
  },
  "dependencies": {
    "big.js": "^6.2.2",
    "dayjs": "^1.11.13",
    "lodash-es": "^4.17.21"
